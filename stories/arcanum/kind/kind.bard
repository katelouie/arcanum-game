:: TheKind.Router ^DREAM:KIND
@if the_kind.sessions_completed == 0:
    -> TheKind.Session1.Start
@elif the_kind.sessions_completed == 1:
    -> TheKind.Session2.Start
@elif the_kind.sessions_completed == 2:
    -> TheKind.Session3.Start
@else:
    # All three sessions completed
    The Kind rests. The store is warm. The rain continues.
@endif